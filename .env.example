# I2C / PSU
I2C_BUS=auto
PSU_ADDRESSES=0x58,0x59

# MQTT broker (reached via shared network namespace -> localhost)
MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_USER=fsp2mqtt
MQTT_PASS=changeme

# Topic / device identity
DISCOVERY_PREFIX=homeassistant
DEVICE_ID=fsp_twin_psu
DEVICE_NAME=FSP Twin PSU
DEVICE_MANUFACTURER=FSP-GROUP
# DEVICE_MODEL is auto-detected from MFR_MODEL if left empty
DEVICE_MODEL=
STATE_PREFIX=fsp/fsp_twin_psu

# Polling interval (seconds)
POLL_INTERVAL=15
